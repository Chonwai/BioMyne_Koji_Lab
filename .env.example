# BioMyne Koji Phase 1 environment variables

# Hermes Agent
HERMES_UID=10000
HERMES_GID=10000
API_SERVER_KEY=koji-phase1-local

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_TAG=
OLLAMA_NUM_CTX=32768
OPENAI_API_KEY=ollama-local-no-auth

# Firecrawl
FIRECRAWL_KEY=
SOURCE_MANIFEST_PATH=ops/source-manifests/biotech.yaml
MAX_ARTICLES_PER_SOURCE=15
MAX_ARTICLES_PER_SOURCE_OVERRIDES=STAT News=20,Nature Biotechnology=18,Science=10,bioRxiv=12,arXiv Quantitative Biology=12
DISCOVERY_MAP_LIMIT_MULTIPLIER=20
DISCOVERY_MAP_MIN_LIMIT=80
DISCOVERY_MIN_CANDIDATE_SCORE=4
DISCOVERY_DATE_SCORE_BONUS=4
DISCOVERY_RSS_STRICT_BONUS=6
DISCOVERY_SURFACE_COOLDOWN_HOURS=6
CATEGORY_TARGET_MAX_PAGES=3
CATEGORY_TARGET_MIN_LIMIT=10
CATEGORY_TARGET_MAX_LINKS_PER_PAGE=250
NATURE_SUPPLEMENTAL_SITEMAP_MONTHS=4
ANALYSIS_PROMPT_VERSION=biotech-article-analysis-v2
SUMMARY_MIN_CHARS=220
SUMMARY_MIN_SENTENCES=4

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Langfuse
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=change-me-in-production
LANGFUSE_SALT=change-me-in-production

# Delivery channel
DELIVERY_CHANNEL=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Runtime flags
ENABLE_CLOUD_FALLBACK=false
CLOUD_FALLBACK_MODEL=
